<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:helpers="clr-namespace:ISOTankApp.Helpers"
             x:Class="ISOTankApp.Controls.CustomDropdown">

    <Grid>
        <!-- Custom UI Border -->
        <Border Stroke="#CED4DA" StrokeThickness="1" BackgroundColor="White" Padding="10,0" StrokeShape="RoundRectangle 5" HeightRequest="45" InputTransparent="True">
            <Grid>
                <!-- Selected text or placeholder -->
                <Label x:Name="SelectedTextLabel" 
                       Text="{Binding Title, Source={RelativeSource AncestorType={x:Type ContentView}}}" 
                       TextColor="#6C757D" 
                       VerticalOptions="Center" />
                       
                <!-- Dropdown Arrow -->
                <Label Text="&#xf078;" 
                       FontFamily="FontAwesome" 
                       FontSize="12" 
                       TextColor="#6C757D" 
                       HorizontalOptions="End" 
                       VerticalOptions="Center" 
                       Margin="0,0,5,0" 
                       InputTransparent="True"/>
            </Grid>
        </Border>

        <!-- Invisible Native Picker covering the UI -->
        <Picker x:Name="NativePicker"
                Opacity="0"
                Title="{Binding Title, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                ItemsSource="{Binding ItemsSource, Source={RelativeSource AncestorType={x:Type ContentView}}}"
                SelectedItem="{Binding SelectedItem, Source={RelativeSource AncestorType={x:Type ContentView}}, Mode=TwoWay}"
                HorizontalOptions="Fill" 
                VerticalOptions="Fill" />
    </Grid>

</ContentView>
