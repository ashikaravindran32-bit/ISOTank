<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ISOTankApp.Models"
             xmlns:helpers="clr-namespace:ISOTankApp.Helpers"
             x:Class="ISOTankApp.Views.ResolutionRequiredPage"
             Title="Resolution Required"
             BackgroundColor="#F3F5F7"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">
            <!-- Header -->
            <HorizontalStackLayout Spacing="10" Margin="0,0,0,10">
                <Label Text="&#xf060;" FontFamily="FontAwesome" FontSize="14" TextColor="#6C757D" VerticalOptions="Center"/>
                <Label x:Name="PageTitleHeader" Text="NEW REPORT" FontSize="14" FontAttributes="Bold" TextColor="#1F3C59" VerticalOptions="Center" TextTransform="Uppercase"/>
            </HorizontalStackLayout>

            <!-- Custom Tab Bar -->
            <Grid Margin="0,0,0,20">
                <BoxView HeightRequest="2" Color="#E9ECEF" VerticalOptions="Start" Margin="50,24,50,0" />
                <Grid ColumnDefinitions="*,*,*,*">
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="5" helpers:CursorHelper.IsPointer="True">
                        <Border StrokeShape="{OnIdiom Phone='RoundRectangle 18', Default='RoundRectangle 25'}" HeightRequest="{OnIdiom Phone=36, Default=50}" WidthRequest="{OnIdiom Phone=36, Default=50}" BackgroundColor="#E9ECEF" Padding="0" Stroke="Transparent" StrokeThickness="0">
                            <Label Text="&#xf0ae;" FontFamily="FontAwesome" FontSize="{OnIdiom Phone=14, Default=20}" TextColor="#28A745" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="TANK INFO" FontSize="{OnIdiom Phone=9, Default=12}" FontAttributes="Bold" TextColor="#28A745" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="5" helpers:CursorHelper.IsPointer="True">
                        <Border StrokeShape="{OnIdiom Phone='RoundRectangle 18', Default='RoundRectangle 25'}" HeightRequest="{OnIdiom Phone=36, Default=50}" WidthRequest="{OnIdiom Phone=36, Default=50}" BackgroundColor="#E9ECEF" Padding="0" Stroke="Transparent" StrokeThickness="0">
                            <Label Text="&#xf03e;" FontFamily="FontAwesome" FontSize="{OnIdiom Phone=14, Default=20}" TextColor="#28A745" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="UPLOAD PHOTOS" FontSize="{OnIdiom Phone=9, Default=12}" FontAttributes="Bold" TextColor="#28A745" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    
                    <!-- Active -->
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="5" helpers:CursorHelper.IsPointer="True">
                        <Border StrokeShape="{OnIdiom Phone='RoundRectangle 18', Default='RoundRectangle 25'}" HeightRequest="{OnIdiom Phone=36, Default=50}" WidthRequest="{OnIdiom Phone=36, Default=50}" BackgroundColor="#28A745" Padding="0" Stroke="Transparent" StrokeThickness="0">
                            <Label Text="&#xf046;" FontFamily="FontAwesome" FontSize="{OnIdiom Phone=14, Default=20}" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="CHECKLIST" FontSize="{OnIdiom Phone=9, Default=12}" FontAttributes="Bold" TextColor="#28A745" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    
                    <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="5" helpers:CursorHelper.IsPointer="True">
                        <Border StrokeShape="{OnIdiom Phone='RoundRectangle 18', Default='RoundRectangle 25'}" HeightRequest="{OnIdiom Phone=36, Default=50}" WidthRequest="{OnIdiom Phone=36, Default=50}" BackgroundColor="#E9ECEF" Padding="0" Stroke="Transparent" StrokeThickness="0">
                            <Label Text="&#xf06e;" FontFamily="FontAwesome" FontSize="{OnIdiom Phone=14, Default=20}" TextColor="#28A745" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="REVIEW &amp; SUBMIT" FontSize="{OnIdiom Phone=9, Default=12}" FontAttributes="Bold" TextColor="#28A745" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>
            </Grid>

            <!-- Orange Warning Banner -->
            <Frame BackgroundColor="#FFF3CD" BorderColor="#FFEEBA" CornerRadius="5" Padding="15" HasShadow="False" Margin="0,0,0,10">
                <VerticalStackLayout Spacing="5">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="&#xf071;" FontFamily="FontAwesome" FontSize="14" TextColor="#856404" VerticalOptions="Center"/>
                        <Label Text="Resolution Required" FontAttributes="Bold" FontSize="14" TextColor="#856404" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Text="Please update the status of these flagged items before final submission." FontSize="12" TextColor="#856404" Margin="22,0,0,0"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Faulty Items List -->
            <StackLayout x:Name="FaultyItemsLayout" BindableLayout.ItemTemplateSelector="{x:Null}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:ChecklistItem">
                        <VerticalStackLayout Spacing="0" Margin="0,0,0,20">
                            
                            <Frame BackgroundColor="White" BorderColor="#E9ECEF" CornerRadius="5" Padding="20" HasShadow="False">
                                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto" RowSpacing="15">
                                    
                                    <!-- Header: Fault Badge and Title -->
                                    <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="10" VerticalOptions="Center">
                                        <Label Text="FAULT" TextColor="#DC3545" FontAttributes="Bold" FontSize="10" Padding="5,2" BackgroundColor="#F8D7DA" VerticalOptions="Center"/>
                                        <Label Text="{Binding SubJobName}" FontSize="13" FontAttributes="Bold" TextColor="#1F3C59" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                    <!-- Subtitle Original SN -->
                                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding Sn, StringFormat='Original SN: {0}'}" FontSize="11" TextColor="#6C757D" Margin="0,-10,0,0"/>

                                    <!-- Resolution Comment Box -->
                                    <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="5">
                                        <Label Text="UPDATE COMMENT / ACTION TAKEN" FontSize="10" FontAttributes="Bold" TextColor="#6C757D"/>
                                        <Frame BackgroundColor="#F8F9FA" BorderColor="#CED4DA" CornerRadius="5" Padding="0" HasShadow="False">
                                            <Editor Text="{Binding Comment}" HeightRequest="60" BackgroundColor="Transparent" FontSize="13" TextColor="#495057"/>
                                        </Frame>
                                    </VerticalStackLayout>

                                    <!-- Toggle Indicator -->
                                    <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" WidthRequest="20" HeightRequest="20" BackgroundColor="{Binding StatusColor}" Padding="0" StrokeShape="RoundRectangle 10" VerticalOptions="Center" helpers:CursorHelper.IsPointer="True">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnItemResolvedTapped" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                    </Border>
                                    
                                </Grid>
                            </Frame>
                            
                        </VerticalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>

            <!-- Action Buttons -->
            <HorizontalStackLayout Spacing="{OnIdiom Phone=10, Default=15}" Margin="0,10,0,20" HorizontalOptions="End">
                <Button Text="CANCEL" Clicked="OnCancelTapped" helpers:CursorHelper.IsPointer="True" BackgroundColor="#6C757D" TextColor="White" CornerRadius="5" WidthRequest="{OnIdiom Phone=100, Default=120}" HeightRequest="45" FontSize="{OnIdiom Phone=12, Default=14}" FontAttributes="Bold" Padding="0"/>
                <Button Text="SAVE &amp; CONTINUE" Clicked="OnSaveContinueTapped" helpers:CursorHelper.IsPointer="True" BackgroundColor="#28A745" TextColor="White" CornerRadius="5" WidthRequest="{OnIdiom Phone=140, Default=170}" HeightRequest="45" FontSize="{OnIdiom Phone=12, Default=14}" FontAttributes="Bold" Padding="0"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
