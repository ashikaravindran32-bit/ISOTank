<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:ISOTankApp.Helpers"
             x:Class="ISOTankApp.Views.UploadPhotosPage"
             Title="Upload Photos"
             BackgroundColor="#F3F5F7"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <!-- Header -->
            <HorizontalStackLayout Spacing="10" Margin="0,0,0,10">
                <Label Text="&#xf060;" FontFamily="FontAwesome" FontSize="14" TextColor="#6C757D" VerticalOptions="Center"/>
                <Label x:Name="PageTitleHeader" Text="NEW REPORT" FontSize="14" FontAttributes="Bold" TextColor="#1F3C59" VerticalOptions="Center" TextTransform="Uppercase"/>
            </HorizontalStackLayout>

            <!-- Custom Tab Bar -->
            <Grid Margin="0,0,0,20">
                <BoxView HeightRequest="2" Color="#E9ECEF" VerticalOptions="Start" Margin="50,24,50,0" />
                <Grid ColumnDefinitions="*,*,*,*">
                    <!-- Tank Info Tab -->
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="5" helpers:CursorHelper.IsPointer="True">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTankInfoTapped" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Border StrokeShape="{OnIdiom Phone='RoundRectangle 18', Default='RoundRectangle 25'}" HeightRequest="{OnIdiom Phone=36, Default=50}" WidthRequest="{OnIdiom Phone=36, Default=50}" BackgroundColor="#E9ECEF" Padding="0" Stroke="Transparent" StrokeThickness="0">
                            <Label Text="&#xf0ae;" FontFamily="FontAwesome" FontSize="{OnIdiom Phone=14, Default=20}" TextColor="#28A745" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="TANK INFO" FontSize="{OnIdiom Phone=9, Default=12}" FontAttributes="Bold" TextColor="#28A745" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    
                    <!-- Upload Photos Tab (Active) -->
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="5" helpers:CursorHelper.IsPointer="True">
                        <Border StrokeShape="{OnIdiom Phone='RoundRectangle 18', Default='RoundRectangle 25'}" HeightRequest="{OnIdiom Phone=36, Default=50}" WidthRequest="{OnIdiom Phone=36, Default=50}" BackgroundColor="#28A745" Padding="0" Stroke="Transparent" StrokeThickness="0">
                            <Label Text="&#xf03e;" FontFamily="FontAwesome" FontSize="{OnIdiom Phone=14, Default=20}" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="UPLOAD PHOTOS" FontSize="{OnIdiom Phone=9, Default=12}" FontAttributes="Bold" TextColor="#28A745" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    
                    <!-- Checklist Tab -->
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="5" helpers:CursorHelper.IsPointer="True">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChecklistTapped" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Border StrokeShape="{OnIdiom Phone='RoundRectangle 18', Default='RoundRectangle 25'}" HeightRequest="{OnIdiom Phone=36, Default=50}" WidthRequest="{OnIdiom Phone=36, Default=50}" BackgroundColor="#E9ECEF" Padding="0" Stroke="Transparent" StrokeThickness="0">
                            <Label Text="&#xf046;" FontFamily="FontAwesome" FontSize="{OnIdiom Phone=14, Default=20}" TextColor="#28A745" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="CHECKLIST" FontSize="{OnIdiom Phone=9, Default=12}" FontAttributes="Bold" TextColor="#28A745" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    
                    <!-- Review & Submit Tab -->
                    <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="5" helpers:CursorHelper.IsPointer="True">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnReviewTapped" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Border StrokeShape="{OnIdiom Phone='RoundRectangle 18', Default='RoundRectangle 25'}" HeightRequest="{OnIdiom Phone=36, Default=50}" WidthRequest="{OnIdiom Phone=36, Default=50}" BackgroundColor="#E9ECEF" Padding="0" Stroke="Transparent" StrokeThickness="0">
                            <Label Text="&#xf06e;" FontFamily="FontAwesome" FontSize="{OnIdiom Phone=14, Default=20}" TextColor="#28A745" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="REVIEW &amp; SUBMIT" FontSize="{OnIdiom Phone=9, Default=12}" FontAttributes="Bold" TextColor="#28A745" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>
            </Grid>

            <!-- Photos Container -->
            <Frame BackgroundColor="White" CornerRadius="10" HasShadow="True" Padding="30" BorderColor="Transparent">
                <VerticalStackLayout Spacing="20">
                
                    <!-- FlexLayout for Image Types -->
                    <FlexLayout x:Name="PhotosFlexLayout" Wrap="Wrap" JustifyContent="Start" AlignItems="Start" AlignContent="Start" Margin="0,10,0,0" BindableLayout.ItemTemplateSelector="{x:Null}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Spacing="8" Margin="10" WidthRequest="{OnIdiom Phone=130, Default=200}">
                                    <!-- Dashed Border Box -->
                                    <Border Stroke="#CED4DA" StrokeThickness="1.5" StrokeDashArray="6,6" BackgroundColor="Transparent" StrokeShape="RoundRectangle 8" Padding="0" HeightRequest="{OnIdiom Phone=100, Default=150}" helpers:CursorHelper.IsPointer="True">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPhotoTapped" CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Grid>
                                            <!-- Placeholder content (shows when no image is selected) -->
                                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" IsVisible="{Binding ShowPlaceholder}">
                                                <Label Text="&#xf030;" FontFamily="FontAwesome" FontSize="{OnIdiom Phone=20, Default=28}" TextColor="#ADB5BD" HorizontalOptions="Center"/>
                                                <Label Text="{Binding Category.Name}" FontSize="{OnIdiom Phone=10, Default=12}" FontAttributes="Bold" TextColor="#6C757D" HorizontalTextAlignment="Center" TextTransform="Uppercase"/>
                                            </VerticalStackLayout>
                                            
                                            <!-- Uploaded Image Preview (shows when an image is selected) -->
                                            <Image Source="{Binding ImagePath}" Aspect="AspectFill" IsVisible="{Binding HasImage}" />
                                            
                                            <!-- Marking Checkbox -->
                                            <Border StrokeThickness="4" BackgroundColor="White" StrokeShape="RoundRectangle 15"
                                                    WidthRequest="30" HeightRequest="30" HorizontalOptions="End" VerticalOptions="End" Margin="10"
                                                    IsVisible="{Binding HasImage}" helpers:CursorHelper.IsPointer="True">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnMarkPhotoTapped" CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsMarked}" Value="True">
                                                        <Setter Property="Stroke" Value="#DC3545" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsMarked}" Value="False">
                                                        <Setter Property="Stroke" Value="#E9ECEF" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <!-- Label below box -->
                                    <Label Text="{Binding Category.Key}" FontSize="10" FontAttributes="Bold" TextColor="#ADB5BD" HorizontalTextAlignment="Center" TextTransform="Uppercase" Margin="0,5,0,0" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                    
                </VerticalStackLayout>
            </Frame>
            
            <HorizontalStackLayout Spacing="{OnIdiom Phone=10, Default=15}" Margin="0,10,0,0" HorizontalOptions="End">
                <Button Text="CANCEL" Clicked="OnTankInfoTapped" helpers:CursorHelper.IsPointer="True" BackgroundColor="#6C757D" TextColor="White" CornerRadius="5" WidthRequest="{OnIdiom Phone=100, Default=120}" HeightRequest="45" FontSize="{OnIdiom Phone=12, Default=14}" FontAttributes="Bold" Padding="0"/>
                <Button Text="SAVE &amp; NEXT" Clicked="OnSavePhotosClicked" helpers:CursorHelper.IsPointer="True" BackgroundColor="#28A745" TextColor="White" CornerRadius="5" WidthRequest="{OnIdiom Phone=120, Default=160}" HeightRequest="45" FontSize="{OnIdiom Phone=12, Default=14}" FontAttributes="Bold" Padding="0"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
